# Postgres connection string (pooled — use for DATABASE_URL, e.g. Supabase's pgbouncer port)
DATABASE_URL=

# Postgres direct connection (non-pooled — required for Prisma migrations)
DIRECT_URL=

# Secret used to sign NextAuth JWTs. Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=

# The deployed app's URL (e.g. https://your-app.vercel.app). Use http://localhost:3000 locally.
NEXTAUTH_URL=

# Anthropic API key, used by the AI Team Builder's /api/teams/analyze route
ANTHROPIC_API_KEY=
